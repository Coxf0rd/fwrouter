#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone


API_URL = "http://127.0.0.1:5000/api/v2/jobs"
TERMINAL_STATUSES = {"success", "failed", "cancelled"}
DEFAULT_WAIT_SECONDS = 240


def build_payload() -> dict:
    return {
        "job_type": "subscription_refresh_prepare",
        "lock_key": "subscription_refresh",
        "requested_by": "systemd_timer",
        "input_data": {
            "reason": "periodic_subscription_refresh",
            "scheduled_at": datetime.now(timezone.utc).isoformat(),
        },
        "run_now": True,
    }


def api_json(path: str = "", *, data: dict | None = None, timeout: int = 120) -> dict:
    method = "POST" if data is not None else "GET"
    request = urllib.request.Request(
        f"{API_URL}{path}",
        data=json.dumps(data).encode("utf-8") if data is not None else None,
        headers={"Content-Type": "application/json"},
        method=method,
    )

    with urllib.request.urlopen(request, timeout=timeout) as response:
        return json.loads(response.read().decode("utf-8"))


def wait_for_terminal_job(response_payload: dict) -> dict:
    job = response_payload.get("data", {}).get("job", {})
    job_id = job.get("job_id")
    if not job_id or job.get("status") in TERMINAL_STATUSES:
        return response_payload

    wait_seconds = int(os.environ.get("FWROUTER_SUBSCRIPTION_REFRESH_WAIT_SECONDS", DEFAULT_WAIT_SECONDS))
    deadline = time.monotonic() + max(wait_seconds, 1)

    while time.monotonic() < deadline:
        time.sleep(2)
        current_payload = api_json(f"/{job_id}", timeout=30)
        current_job = current_payload.get("data", {}).get("job", {})
        if current_job.get("status") in TERMINAL_STATUSES:
            return current_payload

    return current_payload


def main() -> int:
    dry_run = "--dry-run" in sys.argv
    payload = build_payload()

    if dry_run:
        print(json.dumps(payload, ensure_ascii=False, sort_keys=True))
        return 0

    try:
        response_payload = wait_for_terminal_job(api_json(data=payload))
    except urllib.error.URLError as exc:
        print(f"ERROR: failed to call FWRouter API: {exc}", file=sys.stderr)
        return 1
    except json.JSONDecodeError as exc:
        print(f"ERROR: FWRouter API returned invalid JSON: {exc}", file=sys.stderr)
        return 1

    print(json.dumps(response_payload, ensure_ascii=False, sort_keys=True))

    if response_payload.get("ok") is not True:
        print("ERROR: FWRouter API returned ok=false", file=sys.stderr)
        return 1

    job = response_payload.get("data", {}).get("job", {})
    if job.get("status") != "success":
        print(f"ERROR: job status is not success: {job.get('status')}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
