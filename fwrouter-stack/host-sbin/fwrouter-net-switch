#!/usr/bin/env bash
set -euo pipefail

TARGET="${1:-}"
if [[ "$TARGET" != "1" && "$TARGET" != "2" ]]; then
  echo "Usage: fwrouter-net-switch {1|2}" >&2
  echo "  1 = primary mihomo (full-host/TUN)" >&2
  echo "  2 = mihomo2 (full-host/TUN)" >&2
  exit 1
fi

CONFIG1="/etc/fwrouter/mihomo/config.yaml"
CONFIG2="/etc/fwrouter/mihomo2/config.yaml"
COMPOSE1="/app/fwrouter/docker-compose.mihomo.yml"
COMPOSE2="/app/fwrouter/docker-compose.mihomo2.yml"

if [[ ! -f "$CONFIG1" || ! -f "$CONFIG2" ]]; then
  echo "missing config: $CONFIG1 or $CONFIG2" >&2
  exit 1
fi
if [[ ! -S /dev/net/tun && ! -c /dev/net/tun ]]; then
  echo "missing /dev/net/tun (required for full-host)" >&2
  exit 1
fi

ts="$(date +%Y%m%d-%H%M%S)"
bk="/root/local_backups/net-switch"
mkdir -p "$bk"
cp -a "$CONFIG1" "$bk/mihomo.config.yaml.$ts.bak"
cp -a "$CONFIG2" "$bk/mihomo2.config.yaml.$ts.bak"

TARGET="$TARGET" python3 - <<'PY'
from pathlib import Path
import os

cfg1 = Path("/etc/fwrouter/mihomo/config.yaml")
cfg2 = Path("/etc/fwrouter/mihomo2/config.yaml")
target = os.environ.get("TARGET", "1")

def read_lines(path: Path):
    return path.read_text(encoding="utf-8", errors="replace").splitlines()

def split_tun(lines):
    for i, line in enumerate(lines):
        if line.strip() == "tun:":
            return lines[:i], lines[i:]
    return lines, []

def set_enable(tun_lines, enable: bool):
    out = []
    replaced = False
    for line in tun_lines:
        if line.strip().startswith("enable:"):
            out.append("  enable: " + ("true" if enable else "false"))
            replaced = True
        else:
            out.append(line)
    if not replaced:
        out.insert(1, "  enable: " + ("true" if enable else "false"))
    return out

base1, tun1 = split_tun(read_lines(cfg1))
base2, tun2 = split_tun(read_lines(cfg2))

if not tun1:
    raise SystemExit("tun block not found in primary config")

if not tun2:
    tun2 = tun1[:]

if target == "1":
    tun1 = set_enable(tun1, True)
    tun2 = set_enable(tun2, False)
else:
    tun1 = set_enable(tun1, False)
    tun2 = set_enable(tun2, True)

cfg1.write_text("\n".join(base1 + tun1) + "\n", encoding="utf-8")
cfg2.write_text("\n".join(base2 + tun2) + "\n", encoding="utf-8")
PY

if [[ "$TARGET" == "1" ]]; then
  docker compose -f "$COMPOSE1" up -d --force-recreate
  docker compose -f "$COMPOSE2" up -d --force-recreate
else
  docker compose -f "$COMPOSE2" up -d --force-recreate
  docker compose -f "$COMPOSE1" up -d --force-recreate
fi

TARGET="$TARGET" python3 - <<'PY'
from pathlib import Path
import os, json, urllib.request

cfg1 = Path("/etc/fwrouter/mihomo/config.yaml")
cfg2 = Path("/etc/fwrouter/mihomo2/config.yaml")
target = os.environ.get("TARGET", "1")

def read_secret(path: Path) -> str:
    for raw in path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = raw.strip()
        if line.startswith("secret:"):
            val = line.split(":", 1)[1].strip().strip('"').strip("'")
            return val
    return ""

def get_now(api_base: str, secret: str) -> str:
    req = urllib.request.Request(
        f"{api_base}/proxies/PROXY",
        headers={"Authorization": f"Bearer {secret}"} if secret else {},
    )
    with urllib.request.urlopen(req, timeout=5) as resp:
        data = json.loads(resp.read().decode("utf-8", "replace"))
    return data.get("now") or ""

def set_now(api_base: str, secret: str, name: str) -> None:
    body = json.dumps({"name": name}).encode("utf-8")
    req = urllib.request.Request(
        f"{api_base}/proxies/PROXY",
        data=body,
        method="PUT",
        headers={
            "Content-Type": "application/json",
            **({"Authorization": f"Bearer {secret}"} if secret else {}),
        },
    )
    with urllib.request.urlopen(req, timeout=5):
        pass

secret1 = read_secret(cfg1)
secret2 = read_secret(cfg2)

if target == "2":
    src_api, src_secret = "http://127.0.0.1:9091", secret1
    dst_api, dst_secret = "http://127.0.0.1:9191", secret2
else:
    src_api, src_secret = "http://127.0.0.1:9191", secret2
    dst_api, dst_secret = "http://127.0.0.1:9091", secret1

try:
    now = get_now(src_api, src_secret)
    if now and now != "DIRECT":
        set_now(dst_api, dst_secret, now)
except Exception:
    pass
PY

echo "OK: switched full-host to mihomo $TARGET"
echo "Rollback:"
echo "  cp -a $bk/mihomo.config.yaml.$ts.bak $CONFIG1"
echo "  cp -a $bk/mihomo2.config.yaml.$ts.bak $CONFIG2"
echo "  docker compose -f $COMPOSE1 up -d --force-recreate"
echo "  docker compose -f $COMPOSE2 up -d --force-recreate"
