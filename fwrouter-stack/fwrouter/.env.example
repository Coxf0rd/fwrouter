POSTGRES_DB=fwrouter
POSTGRES_USER=fwrouter
POSTGRES_PASSWORD=CHANGE_ME

# Optional (currently admin auth is disabled in code)
FWROUTER_ADMIN_PASSWORD=CHANGE_ME
FWROUTER_BIND=0.0.0.0
FWROUTER_PORT=9280

# Mihomo (clash meta) API integration (host network)
MIHOMO_API_BASE=http://127.0.0.1:9191
MIHOMO_API_SECRET=CHANGE_ME
MIHOMO_PROVIDER_NAME=subscription

# Optional: suffix to strip from tailscale peer DNS names in UI, e.g. ".vpn.example.com"
FWROUTER_TS_SUFFIX=.vpn.example.com

# Optional: path to active Mihomo config (used by UI to update subscription URL).
# Default: /etc/fwrouter/mihomo/config.yaml
FWR_MIHOMO_CONFIG=/etc/fwrouter/mihomo/config.yaml
