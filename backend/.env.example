FWROUTER_ENVIRONMENT=production
FWROUTER_DEBUG=false

FWROUTER_BIND_HOST=127.0.0.1
FWROUTER_BIND_PORT=5000

FWROUTER_WATCHDOG_SCHEDULER_ENABLED=true
FWROUTER_WATCHDOG_SCHEDULER_LOG_EVENTS=false
FWROUTER_WATCHDOG_AUTO_INTERVAL_SECONDS=20
FWROUTER_WATCHDOG_TRAFFIC_WINDOW_SECONDS=240
FWROUTER_RULES_BIG_DIRECT_URLS=[]
FWROUTER_RULES_BIG_VPN_URLS=[]
FWROUTER_RULES_FETCH_TIMEOUT_SECONDS=90
FWROUTER_RULES_FETCH_USER_AGENT=FWRouterRulesFetcher/1.0
FWROUTER_RULES_FETCH_MAX_BYTES=4194304

# Optional: override runtime roots as JSON when installing outside the default server tree.
# FWROUTER_PATHS={"etc_dir":"/etc/fwrouter","state_dir":"/var/lib/fwrouter-v2","log_dir":"/var/log/fwrouter","run_dir":"/run/fwrouter-v2"}
